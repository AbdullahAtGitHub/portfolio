---
---

<section
  id="hero"
  class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-5xl flex-col justify-center px-4 py-20 sm:px-6"
  aria-labelledby="hero-heading"
>
  <div class="flex flex-col-reverse items-center gap-10 sm:flex-row sm:items-center sm:gap-16">

    <!-- Text content -->
    <div class="flex-1 text-center sm:text-left">
      <!-- Terminal prompt label -->
      <p class="font-mono-accent mb-5 flex items-center justify-center gap-2 text-sm tracking-wider text-sky-500 dark:text-sky-400 sm:justify-start">
        <span class="text-zinc-500 dark:text-zinc-600">~/</span>
        muhammedabdullah340@gmail.com
        <span class="inline-block h-4 w-0.5 animate-pulse bg-sky-400" aria-hidden="true"></span>
      </p>

      <h1
        id="hero-heading"
        class="mb-3 text-4xl font-bold leading-tight tracking-tight text-zinc-900 sm:text-5xl lg:text-6xl dark:text-zinc-50"
      >
        Muhammad<br class="hidden sm:block" /> Abdullah
      </h1>

      <p class="mb-4 text-xl font-semibold text-zinc-500 dark:text-zinc-400 sm:text-2xl">
        Senior Backend Engineer
      </p>

      <p class="mb-10 max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-lg mx-auto sm:mx-0">
        Backend engineer who builds high-availability financial and enterprise systems in <span class="font-mono-accent text-sky-500 dark:text-sky-400">Java</span>, <span class="font-mono-accent text-sky-500 dark:text-sky-400">Python</span>, and <span class="font-mono-accent text-sky-500 dark:text-sky-400">Go</span>, and makes slow systems fast.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap justify-center gap-3 sm:justify-start">
        <a
          href="mailto:muhammedabdullah340@gmail.com"
          class="inline-flex items-center gap-2 rounded-md bg-sky-500 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-sky-400 hover:shadow-lg hover:shadow-sky-500/25"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          Get in touch
        </a>
        <a
          href="https://github.com/AbdullahAtGitHub"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-zinc-300 px-5 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:border-zinc-500 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/muhammad-abdullah-92ab90201"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-zinc-300 px-5 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:border-zinc-500 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="/MUHAMMAD_ABDULLAH_CV.pdf"
          download
          class="inline-flex items-center gap-2 rounded-md border border-zinc-300 px-5 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:border-zinc-500 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Download CV
        </a>
      </div>
    </div>

    <!-- Avatar -->
    <div class="flex-shrink-0">
      <div class="relative">
        <!-- Glow ring -->
        <div class="absolute inset-0 rounded-full bg-sky-400/20 blur-xl scale-110" aria-hidden="true"></div>
        <!-- Photo -->
        <div class="relative h-44 w-44 overflow-hidden rounded-full ring-2 ring-sky-400/50 ring-offset-4 ring-offset-zinc-50 dark:ring-offset-zinc-950 sm:h-52 sm:w-52 lg:h-60 lg:w-60">
          <img
            src="/avatar.jpeg"
            alt="Muhammad Abdullah"
            class="h-full w-full object-cover object-[center_15%]"
            width="240"
            height="240"
            loading="eager"
            onerror="this.parentElement.parentElement.parentElement.style.display='none'"
          />
        </div>
      </div>
    </div>

  </div>
</section>
