---
const roles = [
  {
    title: 'Backend Software Engineer',
    company: 'ExperLabs',
    period: 'March 2023 to Present',
    bullets: [
      { metric: '$650K+', text: 'in projected annual savings for FBBrands Inc. (US enterprise client) via an end-to-end sourcing and costing platform processing vendor quotations from 20+ countries.' },
      { metric: '98% faster', text: 'critical pricing API, from 4+ minutes to roughly 5 seconds, through query-plan analysis, indexing, Redis caching, and backend redesign.' },
      { metric: '95%+ reduction', text: 'in ETL and reporting runtime, from 5 to 10 hours down to about 20 minutes, with 50% lower memory consumption.' },
      { metric: 'Zero downtime', text: 'migration across major Spring Boot and Java versions on a multi-brand e-commerce middleware platform, adding multi-tenancy, API versioning, and Redis-based distributed caching.' },
      { metric: 'Full ownership', text: 'of backend services in FastAPI and PostgreSQL: API design, RBAC, Microsoft SSO, and automated synchronization. AWS production via GitHub Actions CI/CD, Docker, and logistics integrations with DHL, FedEx, and PBI.' },
    ],
    stack: ['FastAPI', 'PostgreSQL', 'Spring Boot 3.2', 'Java 17', 'Redis', 'AWS', 'Docker', 'GitHub Actions'],
  },
  {
    title: 'Associate Software Engineer',
    company: 'i2c Inc.',
    period: 'February 2022 to March 2023',
    bullets: [
      { metric: 'Millions of users', text: 'supported on a global card transaction platform with strict uptime, consistency, and latency requirements.' },
      { metric: 'Sub-100ms', text: 'response times maintained across mission-critical financial transaction services in a distributed, high-throughput environment.' },
      { metric: '40% fewer', text: 'regression defects after writing 200+ JUnit tests and refactoring legacy Java services, backed by SQL optimization, indexing, and schema refactoring.' },
    ],
    stack: ['Java', 'JUnit', 'SQL', 'Distributed Systems'],
  },
];
---

<section id="work" class="mx-auto max-w-5xl px-4 py-20 sm:px-6" aria-labelledby="work-heading">
  <div class="fade-in">
    <p class="font-mono-accent mb-3 text-xs uppercase tracking-widest text-sky-500 dark:text-sky-400">Experience</p>
    <h2 id="work-heading" class="mb-12 text-2xl font-bold text-zinc-900 sm:text-3xl dark:text-zinc-50">
      Selected work and impact
    </h2>

    <div class="space-y-10">
      {roles.map((role) => (
        <article class="relative rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-zinc-700 sm:p-8">
          <!-- Left accent bar -->
          <div class="absolute left-0 top-6 bottom-6 w-0.5 rounded-full bg-sky-400" aria-hidden="true"></div>

          <div class="mb-6 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4">
            <div>
              <h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-100">{role.title}</h3>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">{role.company}</p>
            </div>
            <span class="font-mono-accent sm:ml-auto text-xs text-zinc-400 whitespace-nowrap">{role.period}</span>
          </div>

          <ul class="space-y-3" role="list">
            {role.bullets.map((b) => (
              <li class="flex gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sky-400/60" aria-hidden="true" />
                <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                  <span class="text-metric font-semibold">{b.metric}</span>{' '}{b.text}
                </p>
              </li>
            ))}
          </ul>

          <div class="mt-5 flex flex-wrap gap-2">
            {role.stack.map((tech) => (
              <span class="font-mono-accent rounded-md bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                {tech}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
